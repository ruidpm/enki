# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# ── Optional: search ─────────────────────────────────────────────────────────
# Required only if using the web_search tool
# BRAVE_SEARCH_API_KEY=your_brave_search_api_key_here

# ── Optional: database paths (defaults shown) ────────────────────────────────
# AUDIT_DB_PATH=data/audit.db
# MEMORY_DB_PATH=data/memory.db
# TASKS_DB_PATH=data/tasks.db
# AUDIT_DEBUG_DB_PATH=data/audit_debug.db

# ── Optional: cost controls (defaults shown) ─────────────────────────────────
# MAX_TOKENS_PER_SESSION=100000
# MAX_DAILY_COST_USD=5.0
# MAX_MONTHLY_COST_USD=30.0
# MAX_TOOL_CALLS_PER_TURN=10
# MAX_LLM_CALLS_PER_SESSION=50
# MAX_AUTONOMOUS_TURNS=20
# SESSION_TIMEOUT_HOURS=4
# LOOP_DETECTION_THRESHOLD=3

# ── Optional: model routing ──────────────────────────────────────────────────
# DEFAULT_MODEL=claude-sonnet-4-6

# ── Optional: email read (IMAP) — tool not registered if unset ───────────────
# IMAP_HOST=imap.gmail.com
# IMAP_USER=you@gmail.com
# IMAP_PASSWORD=your_app_password

# ── Optional: debug audit (Tier 3) ──────────────────────────────────────────
# DEBUG_AUDIT=false

# ── Optional: GitHub token — needed for gh gist create ───────────────────────
# Create at https://github.com/settings/tokens with 'gist' scope
# GH_TOKEN=ghp_...
